# ─────────────────────────────────────────────────────────────────────────────
#  Bender 3.0 — configuración
#  Copia este archivo a `.env` y rellena tus valores. NUNCA subas el `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Credenciales (obligatorias) ---
# Token del bot de Discord: https://discord.com/developers/applications
DISCORD_TOKEN=

# Clave de OpenRouter (compatible con la API de OpenAI): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Clave de Groq para Whisper STT: https://console.groq.com/keys
GROQ_API_KEY=

# --- IDs del servidor de Discord (clic derecho → Copiar ID, con Modo Desarrollador activado) ---
GUILD_ID=
LIMITED_ROLE_ID=
LOGIN_CHANNEL_ID=
VOICE_CREATOR_ID=
AI_CHANNEL_ID=
PINNED_RESPONSE_CHANNEL_ID=

# --- Sistema de normas obligatorio +18 ---
# Canal donde se publican las normas (ej: #✟)
RULES_CHANNEL_ID=
# Canal para anuncios de normas con @everyone (ej: #⛧︲chat)
NOTIFICATIONS_CHANNEL_ID=
# Emoji para aceptar normas (formato <:nombre:id> o emoji unicode como ✅)
RULES_ACCEPT_EMOJI=<:CHEPA:1491625223450132520>
# URL de imagen para el embed de normas (opcional, deja vacío para usar imagen por defecto)
RULES_IMAGE_URL=

# IDs de Discord con permisos de admin sobre el bot (separados por comas)
ADMIN_IDS=

# --- Personalización ---
# Nombre que el bot usa para referirse a vuestro grupo/servidor
SERVER_NAME=el server
# Ciudad por defecto en búsquedas de tiempo/noticias sin lugar explícito
DEFAULT_CITY=Madrid

# --- Integración opcional con WhatsApp (déjalo si no la usas) ---
WHATSAPP_BRIDGE_URL=http://localhost:3000

# --- Transcripción de voz (Groq Whisper) ---
# Límite diario de segundos de audio transcritos (reset automático a medianoche)
GROQ_DAILY_LIMIT=7200

# --- Avanzado (opcional) ---
# Ruta del fichero de estado persistente
DATA_FILE=bender_data.json
